{
  "functions": {
    "api/chat.js": {
      "maxDuration": 30
    },
    "api/estimate.js": {
      "maxDuration": 30
    },
    "api/biz-report.js": {
      "maxDuration": 30
    },
    "api/sms.js": {
      "maxDuration": 30
    },
    "api/telegram-webhook.js": {
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api/biz-report",
      "schedule": "0 0 */2 * *"
    }
  ],
  "headers": [
    {
      "source": "/estimate-widget.html",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/estimate-loader.js",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=86400" }
      ]
    }
  ]
}
