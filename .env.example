# OpenAI (still used by api/chat.js)
OPENAI_API_KEY=sk-...

# Anthropic (used by api/estimate.js — Claude Haiku 4.5)
ANTHROPIC_API_KEY=sk-ant-...

# Airtable
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=appqep8mBMzhS6lFt

# RentCast (property lookup for house-wash quotes)
RENTCAST_API_KEY=...

# Google Calendar
# Paste the ENTIRE contents of your service account JSON as one line
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# The calendar ID to book into (usually your Gmail address)
GOOGLE_CALENDAR_ID=lhppressurewashing@gmail.com

# Telegram push notifications (fires when a quote is saved / booking confirmed)
# Bot token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIjKlmNopQrS-TuVwXyZ
TELEGRAM_CHAT_ID=123456789

# Twilio SMS (inbound webhook on (844) 904-0754 + outbound approved replies)
# Get these from Twilio Console → Account Dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+18449040754

# Marketing dashboard gate
# Required querystring on /dashboard.html?key=... — pick any random string.
# Leave unset (or blank) to make the dashboard public.
DASHBOARD_KEY=changeme-pick-a-random-string
